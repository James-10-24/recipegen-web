# Supabase project credentials. Create a project at https://supabase.com/dashboard
# then copy this file to .env.local and fill in.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# RevenueCat client SDK key (iOS). Production keys start with `appl_`.
# Get yours from RevenueCat dashboard → Project Settings → Apps → iOS.
# Without this set, the app falls back to a baked-in test_ key in dev,
# and refuses to launch in production builds (see lib/purchases.ts).
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=appl_your-key-here

# RevenueCat client SDK key (Android) — set when you ship Android. Starts
# with `goog_`. Same source as the iOS key.
# EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=goog_your-key-here

# Server-only secrets (set via `supabase secrets set` for Edge Functions, never commit):
#   supabase secrets set OPENAI_API_KEY=sk-...
#   supabase secrets set REVENUECAT_WEBHOOK_AUTH=<random-string>
# OPENAI_API_KEY powers generate-recipe / extract-pantry-items / import-recipe.
# REVENUECAT_WEBHOOK_AUTH is the shared secret RevenueCat sends in the
# Authorization header (configure the same value in RevenueCat → Integrations
# → Webhooks). Without it, webhook deliveries are silently dropped.
