{
  "expo": {
    "name": "RecipeGen",
    "slug": "recipegen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "recipegen",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "tech.ideagen.recipegen",
      "deploymentTarget": "15.1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "LSMinimumSystemVersion": "15.1"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "tech.ideagen.recipegen"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "cameraPermission": "RecipeGen uses your camera to identify groceries you've just bought.",
          "photosPermission": "RecipeGen uses your photo library to identify groceries from existing photos."
        }
      ],
      "./plugins/strip-unused-permissions",
      "expo-localization"
    ],
    "experiments": {
      "baseUrl": "/app",
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
